<% variants = local_assigns.key?(:variants) ? local_assigns[:variants] : tool.model_variants.ordered %>

<% if variants.any? %>
  <section class="specs-block models-block">
    <h2 class="specs-title">Models &amp; pricing</h2>
    <table class="models-table">
      <thead>
        <tr><th>Model</th><th>Best for</th><th>API price</th><th>Context window</th><th>Free to try</th></tr>
      </thead>
      <tbody>
        <% variants.each do |variant| %>
          <tr>
            <td class="models-name"><%= variant.name %></td>
            <td><%= variant.best_for %></td>
            <td><%= variant.price_summary || "-" %></td>
            <td><%= variant.context_window.present? ? "#{number_with_delimiter(variant.context_window)} tokens" : "-" %></td>
            <td><%= yes_no_or_unknown(variant.free_to_try) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if (checked = variants.filter_map(&:last_verified).max) %>
      <p class="last-checked">Model lineup last checked <%= checked.strftime("%-d %b %Y") %>.</p>
    <% end %>
  </section>
<% end %>
