<% content_for :title, "#{@tool.name} — AI Finder" %>

<article class="detail tool-detail" style="--brand: <%= tool_brand_color(@tool) %>" data-controller="logo-color">
  <header class="detail-band">
    <%= tool_logo(@tool, css_class: "detail-logo") %>
    <div class="detail-band-main">
      <h1 class="detail-name"><%= @tool.name %></h1>
      <% if @tool.provider.present? %>
        <p class="detail-provider">by <%= @tool.provider %></p>
      <% end %>
      <% score_categories = @tool.score_categories %>
      <% if score_categories.any? %>
        <p class="detail-cats">
          <% unless @tool.scored? %>
            <span class="band-chip band-chip-testing">Not yet tested</span>
          <% end %>
          <% score_categories.each do |c| %>
            <%= link_to c.display_name, search_path(category: c.slug), class: "band-chip" %>
          <% end %>
        </p>
      <% elsif !@tool.scored? %>
        <p class="detail-cats">
          <span class="band-chip band-chip-testing">Not yet tested</span>
        </p>
      <% end %>
    </div>
    <% if (v = @tool.overall_verdict) %>
      <div class="detail-band-score">
        <span class="dbs-num" style="color: <%= score_color(v) %>"><%= score_number(v) %><span class="dbs-den">/10</span></span>
        <span class="dbs-cap">Overall</span>
      </div>
    <% end %>
  </header>

  <section class="product-verdict">
    <% tool_verdict_commentary(@tool).each do |para| %>
      <p class="product-verdict-body"><%= para %></p>
    <% end %>
  </section>

  <% models_available = @tool.verdict_models_available.to_i %>
  <div class="glance-grid">
    <div class="glance-card">
      <span class="glance-ic"><%= icon("currency-dollar", size: 18) %></span>
      <span class="glance-label">Price</span>
      <span class="glance-val"><%= @tool.display_price_label %></span>
    </div>
    <div class="glance-card">
      <span class="glance-ic"><%= icon("shield-lock", size: 18) %></span>
      <span class="glance-label">Privacy</span>
      <span class="glance-val"><%= @tool.display_privacy_label %></span>
    </div>
    <div class="glance-card">
      <span class="glance-ic"><%= icon("bolt", size: 18) %></span>
      <span class="glance-label">Ease</span>
      <span class="glance-val"><%= @tool.display_ease_label %></span>
    </div>
    <div class="glance-card">
      <span class="glance-ic"><%= icon("sparkles", size: 18) %></span>
      <span class="glance-label">Models</span>
      <span class="glance-val"><%= models_available.positive? ? "#{models_available} available" : "Not listed" %></span>
    </div>
  </div>

  <% breakdown = tool_category_breakdown(@tool, model_variant: @selected_model_variant, sort_by_score: false) %>
  <% scores_unavailable = @selected_model_variant && breakdown.empty? %>
  <% unavailable_backdrop = tool_category_breakdown(@tool, sort_by_score: false).presence || unavailable_score_category_backdrop if scores_unavailable %>
  <% display_breakdown = scores_unavailable ? unavailable_backdrop : breakdown %>
  <% if breakdown.any? || @model_variants.any? %>
    <%= turbo_frame_tag "tool_scores", class: "tool-scores-frame" do %>
      <section class="cat-breakdown" id="how-it-scores">
        <div class="cat-breakdown-head">
          <h2 class="specs-title">How it scores</h2>
          <span class="cat-breakdown-sub">
            <% if scores_unavailable %>
              Not yet tested
            <% else %>
              Across <%= breakdown.size %> tested <%= "category".pluralize(breakdown.size) %>
            <% end %>
          </span>
        </div>
        <% if @model_variants.any? %>
          <% base_score_params = request.query_parameters.except("model_variant") %>
          <nav class="model-score-tabs" aria-label="Score source" data-controller="model-score-tabs" data-model-score-tabs-scope-value="<%= @tool.id %>">
            <span class="model-score-tab-indicator" data-model-score-tabs-target="indicator" aria-hidden="true"></span>
            <%= link_to "All models",
                  tool_path(@tool, base_score_params),
                  class: ["model-score-tab", ("model-score-tab-active" if @selected_model_variant.nil?)].compact.join(" "),
                  data: { turbo_frame: "tool_scores", model_score_tabs_target: "tab" },
                  aria: ({ current: "page" } if @selected_model_variant.nil?) %>
            <% @model_variants.each do |variant| %>
              <% active_variant = @selected_model_variant == variant %>
              <%= link_to variant.name,
                    tool_path(@tool, base_score_params.merge("model_variant" => variant.id)),
                    class: ["model-score-tab", ("model-score-tab-active" if active_variant)].compact.join(" "),
                    data: { turbo_frame: "tool_scores", model_score_tabs_target: "tab" },
                    aria: ({ current: "page" } if active_variant) %>
            <% end %>
          </nav>
        <% end %>
        <% if display_breakdown.any? %>
          <div class="cat-bars-shell<%= " cat-bars-shell-unavailable" if scores_unavailable %>">
            <div class="cat-bars" data-controller="score-bars" aria-hidden="<%= scores_unavailable %>">
              <% display_breakdown.each do |cat| %>
                <%= link_to leaderboard_path(cat[:key]), class: "cat-bar-row", data: { turbo_frame: "_top" } do %>
                  <span class="cat-bar-ic" style="--icon-tint: var(--brand)"><%= icon(cat[:icon], size: 16) %></span>
                  <span class="cat-bar-name"><%= cat[:display_name] %></span>
                  <% score_width = (cat[:score] * 10).round %>
                  <span class="cat-bar-track">
                    <span
                      class="cat-bar-fill"
                      data-score-bars-target="fill"
                      data-score-bars-key="<%= cat[:key] %>"
                      data-score-bars-width="<%= score_width %>"
                      style="width: <%= score_width %>%; background: <%= score_color(cat[:score]) %>"
                    ></span>
                  </span>
                  <span class="cat-bar-score" style="color: <%= score_color(cat[:score]) %>"><%= score_number(cat[:score]) %></span>
                <% end %>
              <% end %>
            </div>
            <% if scores_unavailable %>
              <div class="cat-bars-overlay" role="status">Scores currently unavailable</div>
            <% end %>
          </div>
          <p class="cat-breakdown-foot"><%= link_to "See the full criterion-by-criterion review →", review_tool_path(@tool), data: { turbo_frame: "_top" } %></p>
        <% else %>
          <p class="score-empty">No category scores yet for this model.</p>
        <% end %>
      </section>
    <% end %>
  <% end %>

  <% if @tool.website_url.present? %>
    <p class="detail-visit"><%= link_to "Visit #{@tool.name} →", @tool.website_url, target: "_blank", rel: "noopener", class: "visit-btn",
          data: { controller: "event-logger", action: "click->event-logger#log",
                  "event-logger-type-value": "card_click", "event-logger-tool-value": @tool.id } %></p>
  <% end %>

  <footer class="detail-foot">
    <% if @tool.last_verified.present? %>
      <p class="last-checked">Last checked <%= @tool.last_verified.strftime("%-d %b %Y") %><%= ", pricing confidence: #{@tool.data_pricing_confidence}" if @tool.data_pricing_confidence.present? %>.</p>
    <% end %>
    <p class="disclaimer">Prices and privacy policies change — always confirm on the tool's own site before relying on this.</p>
  </footer>
</article>
