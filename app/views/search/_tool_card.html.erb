<article class="card">
  <header class="card-head">
    <% search_context = local_assigns.fetch(:search_context, SearchContext.new) %>
    <h3 class="card-name"><%= link_to tool.name, tool_path(tool, search_context.query_params) %></h3>
    <% if tool.provider.present? %><span class="card-provider">by <%= tool.provider %></span><% end %>
  </header>

  <% if tool.why_this_one.present? %>
    <p class="card-why"><%= tool.why_this_one %></p>
  <% end %>

  <ul class="card-labels">
    <li class="label label-price">💸 <%= tool.display_price_label %></li>
    <li class="label label-privacy">🔒 <%= tool.display_privacy_label %></li>
    <li class="label label-ease">🛠️ <%= tool.display_ease_label %></li>
  </ul>

  <% variants = tool.model_variants.sort_by { |v| [v.position, v.id] } %>
  <% if variants.any? %>
    <p class="card-models">
      <span class="card-models-label">Models:</span>
      <% variants.each do |variant| %>
        <span class="model-chip" title="<%= variant.chip_title %>"><%= variant.name %></span>
      <% end %>
    </p>
  <% end %>


  <footer class="card-foot">
    <%= link_to "See the full specs →", tool_path(tool, search_context.query_params), class: "card-link" %>
    <% if tool.website_url.present? %>
      <%= link_to "Visit site", tool.website_url, target: "_blank", rel: "noopener", class: "card-visit",
            data: { controller: "event-logger", action: "click->event-logger#log",
                    "event-logger-type-value": "card_click", "event-logger-tool-value": tool.id } %>
    <% end %>
  </footer>
</article>
