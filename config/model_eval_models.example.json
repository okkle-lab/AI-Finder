{
  "providers": {
    "openrouter": {
      "type": "openai_compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "extra_headers": {
        "X-Title": "Okkle Find Model Evaluation"
      }
    },
    "openai": {
      "type": "openai_compatible",
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "max_tokens_param": "max_completion_tokens",
      "supports_custom_temperature": false
    },
    "github_models": {
      "type": "openai_compatible",
      "base_url": "https://models.github.ai",
      "api_key_env": "GITHUB_MODELS_TOKEN",
      "chat_completions_path": "/inference/chat/completions",
      "extra_headers": {
        "Accept": "application/vnd.github+json",
        "X-GitHub-Api-Version": "2026-03-10"
      }
    },
    "openai_images": {
      "type": "openai_image_generation",
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "request": {
        "image_count": 1,
        "size": "1024x1024",
        "timeout_seconds": 180
      }
    }
  },
  "request": {
    "temperature": 0.2,
    "max_tokens": 1000,
    "timeout_seconds": 120,
    "retries": 2,
    "sleep_seconds": 0.5
  },
  "models": [
    {
      "key": "model_01",
      "name": "Replace with model name",
      "provider": "openrouter",
      "model": "provider/model-id",
      "capabilities": ["text"],
      "enabled": true
    },
    {
      "key": "model_02",
      "name": "Replace with another model",
      "provider": "openrouter",
      "model": "provider/another-model-id",
      "capabilities": ["text"],
      "enabled": false
    },
    {
      "key": "image_01",
      "name": "GPT Image 2",
      "provider": "openai_images",
      "model": "gpt-image-2",
      "capabilities": ["image"],
      "enabled": false
    },
    {
      "key": "github_models_01",
      "name": "GitHub Models GPT-4.1",
      "provider": "github_models",
      "model": "openai/gpt-4.1",
      "capabilities": ["text"],
      "enabled": false
    }
  ]
}
